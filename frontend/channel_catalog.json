  "actuator_capabilities": {
    "led":       ["led", "rgb_light", "rgb"],
    "vibration": ["vib", "vibration", "haptic", "vibration_motor"],
    "audio":     ["audio", "audio_synth", "audio_output", "tone_generator", "audio_feedback"]
  }
}
