    "AX":          {"id": 0,  "label": "ax"},
    "AY":          {"id": 1,  "label": "ay"},
    "AZ":          {"id": 2,  "label": "az"},
    "GX":          {"id": 3,  "label": "gx"},
    "GY":          {"id": 4,  "label": "gy"},
    "GZ":          {"id": 5,  "label": "gz"},
    "ACC_MAG":     {"id": 6,  "label": "acc_mag"},
    "GYRO_MAG":    {"id": 7,  "label": "gyro_mag"},
    "PITCH":       {"id": 8,  "label": "pitch"},
    "ROLL":        {"id": 9,  "label": "roll"},
    "AX_LPF":      {"id": 10, "label": "ax_lpf"},
    "AY_LPF":      {"id": 11, "label": "ay_lpf"},
    "AZ_LPF":      {"id": 12, "label": "az_lpf"},
    "ACC_MAG_LPF": {"id": 13, "label": "acc_mag_lpf"},
    "JERK":        {"id": 14, "label": "jerk"},
    "SHAKE":       {"id": 16, "label": "shake"},
    "STEP":        {"id": 17, "label": "step"},
    "FREEFALL":    {"id": 18, "label": "freefall"},
    "BPM":         {"id": 24, "label": "bpm"},
    "SPO2":        {"id": 25, "label": "spo2"},
    "BPM_AVG":     {"id": 26, "label": "bpm_avg"},
